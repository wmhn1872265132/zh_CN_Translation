#. Translators: Input help mode message for Say Product Name and Version command.
#: addon/globalPlugins/sayProductNameAndVersion.py:29
msgid "Speaks the name, version, and architecture of the application on which you are focused. Press twice to copy the information to the clipboard. Press three times to copy only the version number.Use on Desktop to get Windows version."
msgstr "按一次读出焦点所在应用的名称、版本和架构。连按两次将这些信息复制到剪贴板。连按三次仅复制版本号。可在桌面上使用该命令获取 Windows 版本。"

#. Translators: The word version.
#: addon/globalPlugins/sayProductNameAndVersion.py:45
msgid "version"
msgstr "版本"

#. Translators: This is used when the name of the focused application cannot be found.
#: addon/globalPlugins/sayProductNameAndVersion.py:57
msgid "Application unknown"
msgstr "应用未知"

#. Used when describing Windows build numbers, which are used instead of a version.
#. Translators: The word "build", as in the Windows build number.
#: addon/globalPlugins/sayProductNameAndVersion.py:64
msgid "build"
msgstr "build"

#. Translators: This is used when the version of the focused application cannot be found.
#: addon/globalPlugins/sayProductNameAndVersion.py:76
msgid "not detected"
msgstr "未检测到"

#. Translators: This is the message announced when all information has been copied.
#: addon/globalPlugins/sayProductNameAndVersion.py:103
#, python-brace-format
msgid "Copied {appName} {versionWord} {appVersionAndArch} to the clipboard."
msgstr "已复制 {appName} {versionWord} {appVersionAndArch} 到剪贴板。"

#. Translators: This is the message announced when all information hasn't been copied.
#: addon/globalPlugins/sayProductNameAndVersion.py:108
msgid "Failed to copy application information to the clipboard."
msgstr "未能将应用信息复制到剪贴板。"

#. Translators: The message reporting that only the application's version and architecture were copied.
#: addon/globalPlugins/sayProductNameAndVersion.py:115
#, python-brace-format
msgid "Copied {appVersionAndArch} to the clipboard."
msgstr "已复制 {appVersionAndArch} 到剪贴板。"

#. Copy failure
#. Translators: This is the message announced when all information hasn't been copied.
#: addon/globalPlugins/sayProductNameAndVersion.py:118
msgid "Cannot copy version information to the clipboard."
msgstr "无法将版本信息复制到剪贴板。"

#. Add-on summary
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: buildVars.py:21
msgid "Say Application Name and Version"
msgstr "读出应用名称和版本"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:24
msgid "Speak the name and version of the application you are currently focused on, by pressing NVDA+Shift+v.\n"
"Pressing twice will copy this information to the clipboard, to paste in bug reports, etc.\n"
"Pressing three times copies only the version.\n"
"The key can be remapped.\n"
"Read help to find tips for hearing NVDA and Windows versions.\n"
"Please consider a small donation: https://www.paypal.me/LukeDavis734"
msgstr "按 NVDA+Shift+v，即可读出当前焦点所在应用的名称和版本。\n"
"连按两次可将此信息复制到剪贴板，以便粘贴到错误报告等处。\n"
"连按三次仅复制版本号。\n"
"该快捷键可自定义。\n"
"查阅帮助文档，获取收听 NVDA 与 Windows 版本的相关技巧。\n"
"欢迎小额捐赠：https://www.paypal.me/LukeDavis734"

